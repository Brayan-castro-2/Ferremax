# Variables de Entorno - FERREMAS
# Copia este archivo como .env.local y rellena con tus credenciales reales

# ==============================
# SUPABASE CONFIGURACIÓN
# ==============================
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# ==============================
# MODO DE LA APLICACIÓN
# ==============================
# "mockup" = datos simulados (sin Supabase)
# "production" = conexión real a Supabase
VITE_APP_MODE=mockup
