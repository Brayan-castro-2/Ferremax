# ============================================================
#  FERREMAS — .gitignore
#  Cubre: frontend Vue.js (raíz) + backend Node.js (/backend)
# ============================================================

# ── DEPENDENCIAS ────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── BUILDS ──────────────────────────────────────────────────
dist/
dist-ssr/
build/
*.local

# ── VARIABLES DE ENTORNO (CRÍTICO) ──────────────────────────
# NUNCA subir credenciales, claves de API ni secrets al repo.
# Los archivos .env.example SÍ se suben como referencia.

# Frontend (raíz)
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local

# Backend
backend/.env
backend/.env.local
backend/.env.development
backend/.env.production
backend/.env.staging
backend/.env.*.local

# ── LOGS ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── EDITOR ──────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── SISTEMA OPERATIVO ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db

# ── ARCHIVOS TEMPORALES / CACHÉ ──────────────────────────────
*.tmp
*.temp
.cache/
coverage/
.nyc_output/

# ── ESPECÍFICOS DEL PROYECTO ─────────────────────────────────
# Carpetas duplicadas en raíz (los originales están en src/)
/orquestadores/
/servicios/
/modelos/
