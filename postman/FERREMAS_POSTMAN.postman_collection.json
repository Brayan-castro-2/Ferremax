    {
      "name": "7. Setup — Refill Sierra stock=50 (evita que test 8 falle por stock 0)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{ \"stock\": 50 }"
        },
        "url": "{{baseUrl}}/api/products/2"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Refill también productos 1, 3, 4, 5 en paralelo (bonus para runs largos)",
              "const baseUrl = pm.collectionVariables.get('baseUrl');",
              "const token   = pm.collectionVariables.get('token');",
              "[1, 3, 4, 5].forEach(id => {",
              "  pm.sendRequest({",
              "    url: `${baseUrl}/api/products/${id}`,",
              "    method: 'PUT',",
              "    header: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },",
              "    body: { mode: 'raw', raw: JSON.stringify({ stock: 50 }) }",
              "  }, () => {});",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => { pm.response.to.have.status(200); });",
              "pm.test('Sierra stock refilled a 50', () => {",
              "  pm.expect(pm.response.json().producto.stock).to.equal(50);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "8. POST /api/orders (5+ ítems → descuento 10%)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tipo_entrega\": \"retiro\",\n  \"items\": [\n    { \"producto_id\": 1, \"cantidad\": 1, \"precio_unitario\": 1000 },\n    { \"producto_id\": 2, \"cantidad\": 1, \"precio_unitario\": 1000 },\n    { \"producto_id\": 3, \"cantidad\": 1, \"precio_unitario\": 1000 },\n    { \"producto_id\": 4, \"cantidad\": 1, \"precio_unitario\": 1000 },\n    { \"producto_id\": 5, \"cantidad\": 1, \"precio_unitario\": 1000 }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/orders"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', () => { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json.pedido && json.pedido.id) { pm.collectionVariables.set('orderId', json.pedido.id); }",
              "pm.test('aplicaDescuento true y descuento >0', () => {",
              "  pm.expect(json).to.have.property('aplicaDescuento', true);",
              "  pm.expect(json.descuentoMonto).to.be.above(0);",
              "});",
              "pm.test('mensaje o pedido presente', () => {",
              "  pm.expect(json).to.satisfy(j => j.pedido || j.mensaje);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "9. GET /api/orders/mis-pedidos",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tokenCliente}}"
          }
        ],
        "url": "{{baseUrl}}/api/orders/mis-pedidos"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const loginCliente = {",
              "  url: pm.collectionVariables.get('baseUrl') + '/api/auth/login',",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/json' },",
              "  body: { mode: 'raw', raw: JSON.stringify({",
              "    email: pm.collectionVariables.get('emailCliente'),",
              "    password: pm.collectionVariables.get('passwordCliente')",
              "  })}",
              "};",
              "pm.sendRequest(loginCliente, (err, res) => {",
              "  if (!err && res.code === 200) {",
              "    const j = res.json();",
              "    if (j.token) pm.collectionVariables.set('tokenCliente', j.token);",
              "  }",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => { pm.response.to.have.status(200); });",
              "pm.test('Estructura total + pedidos', () => {",
              "  const j = pm.response.json();",
              "  pm.expect(j).to.have.property('pedidos');",
              "  pm.expect(j.pedidos).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
