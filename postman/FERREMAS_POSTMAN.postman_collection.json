{
  "info": {
    "name": "FERREMAS API — Integración",
    "description": "Colección de pruebas de integración. Variables: baseUrl, token, tokenCliente, tokenVendedor. Credenciales: admin@ferremas.cl / password, cliente@ferremas.cl / password, vendedor@ferremas.cl / password.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "tokenCliente",
      "value": ""
    },
    {
      "key": "tokenVendedor",
      "value": ""
    },
    {
      "key": "emailAdmin",
      "value": "admin@ferremas.cl"
    },
    {
      "key": "passwordAdmin",
      "value": "password"
    },
    {
      "key": "emailCliente",
      "value": "cliente@ferremas.cl"
    },
    {
      "key": "passwordCliente",
      "value": "password"
    },
    {
      "key": "emailVendedor",
      "value": "vendedor@ferremas.cl"
    },
    {
      "key": "passwordVendedor",
      "value": "password"
    },
    {
      "key": "orderId",
      "value": "1"
    },
    {
      "key": "nuevaSucursalId",
      "value": ""
    },
    {
      "key": "nuevoProductoId",
      "value": ""
    },
    {
      "key": "clienteTestEmail",
      "value": ""
    },
    {
      "key": "nuevoPedidoId",
      "value": ""
    },
    {
      "key": "nuevoPagoId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => { pm.response.to.have.status(200); });",
              "pm.test('body.status es OK', () => { pm.expect(pm.response.json()).to.have.property('status','OK'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Login exitoso (admin) → guarda token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"{{emailAdmin}}\",\"password\":\"{{passwordAdmin}}\"}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Respuesta incluye token y usuario', () => {",
              "  pm.expect(json).to.have.property('token');",
              "  pm.expect(json).to.have.property('usuario');",
              "});",
              "if (json.token) { pm.collectionVariables.set('token', json.token); }"
            ]
          }
        }
      ]
    },
    {
      "name": "3. GET /api/auth/me (token válido)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/auth/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('usuario con rol', () => {",
              "  pm.expect(json).to.have.property('usuario');",
              "  pm.expect(json.usuario).to.have.property('rolNombre');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. GET /api/products",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/products"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', () => { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Estructura total + productos', () => {",
              "  pm.expect(json).to.have.property('total');",
              "  pm.expect(json).to.have.property('productos');",
              "  pm.expect(json.productos).to.be.an('array');",
              "});"
